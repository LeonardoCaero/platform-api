meta {
  name: Update Site
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/clients/sites/:siteId
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Updated Site Name",
    "address": "456 Updated Street",
    "city": "Barcelona",
    "notes": "Updated notes",
    "isActive": true
  }
}
