meta {
  name: Create Project
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/projects
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "companyId": "{{companyId}}",
    "name": "New Project",
    "description": "Project description",
    "color": "#10B981",
    "isActive": true
  }
}
