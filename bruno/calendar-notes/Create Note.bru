meta {
  name: Create Note
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/calendar-notes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "companyId": "{{companyId}}",
    "date": "2026-01-20",
    "title": "Team Meeting",
    "content": "Discuss Q1 goals",
    "color": "#3B82F6",
    "isPrivate": false,
    "assigneeUserIds": [],
    "reminderDaysBefore": [1, 3]
  }
}
