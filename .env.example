# [PostgreSQL]
POSTGRES_USER=caero
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=caero_db

# [Server]
NODE_ENV=development
PORT=3000

# [Database]
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# [JWT] — Generate: openssl rand -base64 48
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# [CORS]
CORS_ORIGINS=http://localhost:5173

# [Invites]
COMPANY_INVITE_EXPIRY_HOURS=72
MEMBER_INVITE_EXPIRY_HOURS=168

# [Seed]
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me
SEED_ADMIN_FULLNAME=Admin

# [Push Notifications] — Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# [Frontend] — Baked into Docker image at build time
VITE_API_URL=https://yourdomain.com/api
